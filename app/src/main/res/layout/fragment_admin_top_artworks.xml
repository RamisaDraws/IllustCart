<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Sort Options Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arrange by:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/sort_radio_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_prints_sold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prints Sold"
                    android:textSize="14sp"
                    android:checked="true"
                    android:paddingRight="10dp"
                    android:paddingVertical="8dp"/>

                <RadioButton
                    android:id="@+id/radio_total_earned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Top Earned"
                    android:textSize="14sp"
                    android:paddingRight="10dp"
                    android:paddingVertical="8dp"/>

                <RadioButton
                    android:id="@+id/radio_top_rated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Top Rated"
                    android:textSize="14sp"
                    android:paddingVertical="8dp"/>

            </RadioGroup>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Top Artworks List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/top_artworks_recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <!-- Empty State -->
    <TextView
        android:id="@+id/empty_top_artworks_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No sales data available yet"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>