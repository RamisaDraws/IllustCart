<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/main_content"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation">

        <!-- Profile Header (Always visible at top) -->
        <LinearLayout
            android:id="@+id/profile_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:background="#5C4436">

            <androidx.cardview.widget.CardView
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/profile_picture_image_view"
                    android:padding="1dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:scaleType="centerCrop"/>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content">

                <TextView
                    android:textStyle="bold"
                    android:textColor="#D5B7A6"
                    android:text="Hello there,"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/name"
                    android:text="Loading.."
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/logout"
                android:src="@drawable/baseline_logout_24"
                android:tint="@color/white"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:padding="8dp"/>

            <TextView
                android:visibility="gone"
                android:id="@+id/name21"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Search Bar (Visible only in home view) -->
        <RelativeLayout
            android:id="@+id/search_layout"
            android:layout_margin="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                app:cardElevation="2dp">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:queryHint="Search here..."
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:iconifiedByDefault="false"
                    android:background="@drawable/rounded_corner_bg"/>

            </androidx.cardview.widget.CardView>

        </RelativeLayout>

        <!-- HOME LAYOUT -->
        <ScrollView
            android:id="@+id/home_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="visible">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Main Banner Image -->
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginTop="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmer_view_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/banner_imageview"
                            android:src="@drawable/tosty"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#E0E0E0"
                            android:scaleType="centerCrop"/>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- Category Section -->
                <LinearLayout
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_marginLeft="15dp"
                        android:layout_marginBottom="10dp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:text="Browse by Category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/brandContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp">

                            <!-- FanArt Category -->
                            <LinearLayout
                                android:id="@+id/catFanArt"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="FanArt"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catfanart"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catOriginal"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Original"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catoriginal"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catCharacter"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Character"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catcharacter"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catChibi"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Chibi"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catchibi"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catBackground"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Background"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catbackground"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catIllusta"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="IllustA"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/illusta"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catComic"
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="5dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Comic"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                <androidx.cardview.widget.CardView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:layout_margin="8dp"
                                    app:cardCornerRadius="30dp"
                                    app:cardElevation="4dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/catcomic"
                                        android:scaleType="centerCrop"/>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>

                <!-- Artworks Section -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/artworksSectionTitle"
                        android:padding="8dp"
                        android:paddingLeft="15dp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:text="Artworks for Sale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/noArtworksText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No available Artworks"
                        android:textAlignment="center"
                        android:textSize="16sp"
                        android:textColor="#666666"
                        android:padding="30dp"
                        android:visibility="gone"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/productRecyclerView"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="8dp"/>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- REPLACE THE PRODUCT DETAIL LAYOUT SECTION IN activity_main.xml (around line 449-546) WITH THIS: -->

        <!-- PRODUCT DETAIL LAYOUT -->
        <RelativeLayout
            android:id="@+id/product_detail_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <!-- Scrollable Content -->
            <ScrollView
                android:id="@+id/product_detail_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/sticky_buttons_container"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/detail_product_name"
                        android:textSize="24sp"
                        android:layout_marginBottom="15dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="Artwork Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/detail_product_image"
                            android:layout_width="match_parent"
                            android:layout_height="350dp"
                            android:scaleType="centerCrop"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Flash Sale Badge -->
                    <TextView
                        android:id="@+id/detail_flash_sale_badge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="⚡FLASH SALE!\n10% OFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFE2D8"
                        android:background="@drawable/rounded_button_red"
                        android:padding="12dp"
                        android:textAlignment="center"
                        android:visibility="gone"/>

                    <!-- Flash Sale Countdown -->
                    <TextView
                        android:id="@+id/detail_flash_sale_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:text="ENDS IN 01:30:45"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FF5722"
                        android:textAlignment="center"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/detail_artist"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="#666666"
                        android:text="Artist: "
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:text="Description"
                        android:textSize="14sp"
                        android:textColor="#666666"/>

                    <TextView
                        android:id="@+id/detail_category"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="#666666"
                        android:text="Category: "
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/detail_size"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="#666666"
                        android:text="Size: "
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <!-- Prints Available -->
                    <TextView
                        android:id="@+id/detail_prints_available"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:text="10 prints available"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                    <!-- Original Price (struck through during flash sale) -->
                    <TextView
                        android:id="@+id/detail_original_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:text="$199"
                        android:textSize="18sp"
                        android:textColor="#999999"
                        android:textStyle="italic"
                        android:visibility="gone"/>

                    <!-- Current Price -->
                    <TextView
                        android:id="@+id/detail_price"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="32sp"
                        android:layout_marginBottom="30dp"
                        android:text="$199"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <!-- Ratings Section -->
                    <LinearLayout
                        android:id="@+id/ratings_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginBottom="16dp"/>

                        <!-- Sticky Ratings Header -->
                        <LinearLayout
                            android:id="@+id/ratings_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:background="@color/white">

                            <TextView
                                android:id="@+id/average_rating_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4.7"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐"
                                android:textSize="28sp"
                                android:layout_marginEnd="12dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Artwork Ratings"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"/>

                                <TextView
                                    android:id="@+id/ratings_count_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="(398)"
                                    android:textSize="14sp"
                                    android:textColor="#666666"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Reviews List -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/reviews_recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:nestedScrollingEnabled="false"/>

                        <!-- No Reviews Text -->
                        <TextView
                            android:id="@+id/no_reviews_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No reviews yet"
                            android:textSize="14sp"
                            android:textColor="#999999"
                            android:textAlignment="center"
                            android:padding="20dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <!-- Sticky Buttons at Bottom -->
            <LinearLayout
                android:id="@+id/sticky_buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="@color/white"
                android:elevation="8dp">

                <Button
                    android:id="@+id/add_to_cart_btn"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/white"
                    android:text="Add to Cart"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/rounded_corner_bg_button"/>

                <Button
                    android:id="@+id/buy_now_btn"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:text="Buy Now"
                    android:background="@drawable/rounded_corner_bg_button"/>

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:visibility="visible"
        android:background="@color/white"
        app:itemIconTint="#8E8D8D"
        app:itemTextColor="#020202"
        android:layout_alignParentBottom="true"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_navigation_menu"/>

</RelativeLayout>