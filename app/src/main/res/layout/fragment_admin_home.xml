<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Home Layout - Product List View -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/admin_home_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- AppBarLayout - Contains banner and search (collapsible + sticky) -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="0dp"
            app:elevation="0dp">

            <!-- Banner Section - Scrolls away -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_scrollFlags="scroll">

                <androidx.cardview.widget.CardView
                    android:id="@+id/admin_banner_card"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <ImageView
                        android:id="@+id/admin_banner_imageview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/baseline_image_24"
                        android:background="#E0E0E0"/>

                    <!-- Small upload indicator at bottom-right -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="12dp"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="2dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_upload"
                            app:tint="@color/white"
                            android:layout_marginEnd="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to change"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Search Bar - Sticks at top when banner scrolls away -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:background="@color/white">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="15dp"
                    android:background="@drawable/rounded_corner_bg">

                    <androidx.appcompat.widget.SearchView
                        android:id="@+id/admin_searchView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:queryHint="Search your products..."
                        android:elevation="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:iconifiedByDefault="false"
                        android:background="@drawable/rounded_corner_bg"/>

                </androidx.cardview.widget.CardView>

            </RelativeLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Scrollable Content - Product Listings -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- All Listings Section Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="All Listings"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>

                <!-- No Products Text -->
                <TextView
                    android:id="@+id/admin_no_products_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No products listed yet.\nTap + to add your first product!"
                    android:textAlignment="center"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:padding="32dp"
                    android:visibility="gone"/>

                <!-- Products RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/admin_products_recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="100dp"
                    android:clipToPadding="false"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Product Detail Layout -->
    <RelativeLayout
        android:id="@+id/admin_product_detail_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/admin_sticky_buttons_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Back Button -->
                <ImageView
                    android:id="@+id/admin_detail_back_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#5C4436"/>

                <!-- Product Image -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <ImageView
                        android:id="@+id/admin_detail_product_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>

                </androidx.cardview.widget.CardView>

                <!-- Product Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Product Name -->
                        <TextView
                            android:id="@+id/admin_detail_product_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Product Name"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"/>

                        <!-- Artist -->
                        <TextView
                            android:id="@+id/admin_detail_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Artist: Name"
                            android:textSize="16sp"
                            android:textColor="#666666"/>

                        <!-- Price -->
                        <TextView
                            android:id="@+id/admin_detail_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="$100"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="#FB8C00"/>

                        <!-- Prints Available -->
                        <TextView
                            android:id="@+id/admin_detail_prints_available"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="10 prints available"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#E0E0E0"/>

                        <!-- Description -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Description"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"/>

                        <TextView
                            android:id="@+id/admin_detail_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Product description..."
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:lineSpacingExtra="4dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#E0E0E0"/>

                        <!-- Product Details -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Product Details"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/admin_detail_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Category: Digital Art"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/admin_detail_size"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Size: A4"
                            android:textSize="14sp"
                            android:textColor="#666666"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Ratings Section -->
                <LinearLayout
                    android:id="@+id/admin_ratings_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customer Reviews"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="12dp"/>

                    <!-- Rating Summary -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/admin_average_rating_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.5"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="#FFB300"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginLeft="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_star_filled"
                                    android:layout_marginEnd="2dp"/>

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_star_filled"
                                    android:layout_marginEnd="2dp"/>

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_star_filled"
                                    android:layout_marginEnd="2dp"/>

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_star_filled"
                                    android:layout_marginEnd="2dp"/>

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_star_hollow"/>

                            </LinearLayout>

                            <TextView
                                android:id="@+id/admin_ratings_count_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(24 reviews)"
                                android:textSize="14sp"
                                android:textColor="#666666"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Reviews List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/admin_reviews_recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                    <!-- No Reviews Text -->
                    <TextView
                        android:id="@+id/admin_no_reviews_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No reviews yet"
                        android:textSize="14sp"
                        android:textColor="#999999"
                        android:textAlignment="center"
                        android:padding="20dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- Hidden Sticky Buttons Container (not shown for admin) -->
        <LinearLayout
            android:id="@+id/admin_sticky_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/white"
            android:elevation="8dp"
            android:visibility="gone"/>

    </RelativeLayout>

</RelativeLayout>